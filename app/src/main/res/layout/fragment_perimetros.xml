<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#f0f4f8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perímetro de Figuras Geométricas"
            android:textColor="#1565C0"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"/>

        <!-- Card Círculo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Círculo (Circunferencia)"
                android:textColor="#1a3a6b"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtRadioPerimetro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="Radio"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnPerimetroCirculo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button"
                android:text="Calcular"
                android:textColor="#FFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvResultadoCirculoP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:text="Resultado: "
                android:textColor="#1565C0"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Card Rectángulo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rectángulo"
                android:textColor="#1a3a6b"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtBasePerimetro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="Base"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <EditText
                android:id="@+id/edtAlturaPerimetro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Altura"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnPerimetroRectangulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button"
                android:text="Calcular"
                android:textColor="#FFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvResultadoRectanguloP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:text="Resultado: "
                android:textColor="#1565C0"
                android:textStyle="bold"/>

        </LinearLayout>

        <!-- Card Triángulo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Triángulo"
                android:textColor="#1a3a6b"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edtLado1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:hint="Lado 1"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <EditText
                android:id="@+id/edtLado2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Lado 2"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <EditText
                android:id="@+id/edtLado3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:hint="Lado 3"
                android:inputType="numberDecimal"
                android:padding="12dp" />

            <Button
                android:id="@+id/btnPerimetroTriangulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button"
                android:text="Calcular"
                android:textColor="#FFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvResultadoTrianguloP"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:text="Resultado: "
                android:textColor="#1565C0"
                android:textStyle="bold"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>