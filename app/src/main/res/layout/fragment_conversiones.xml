<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F5F5F5">

    <!-- Título -->
    <!-- Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Conversiones"
        android:textColor="#1565C0"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"/>

    <!-- Spinner para tipo de conversión -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tipo de Conversión"
        android:textColor="#1a3a6b"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <Spinner
        android:id="@+id/spinnerTipoConversion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/abc_spinner_mtrl_am_alpha"/>

    <!-- Campo de entrada -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Valor a convertir:"
        android:textSize="16sp"
        android:textColor="#555555"
        android:layout_marginBottom="8dp"/>

    <EditText
        android:id="@+id/etValorEntrada"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ingresa el valor"
        android:inputType="numberDecimal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <!-- Botón Convertir -->
    <Button
        android:id="@+id/btnConvertir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Convertir"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#6200EE"
        android:layout_marginBottom="24dp"
        android:padding="12dp"/>

    <!-- Resultado -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Resultado:"
        android:textSize="16sp"
        android:textColor="#555555"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvResultado"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="---"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#6200EE"
        android:gravity="center"
        android:padding="16dp"
        android:background="#FFFFFF"/>

</LinearLayout>